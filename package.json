{
  "name": "looptroop",
  "version": "0.3.2",
  "private": true,
  "description": "Local AI coding orchestration for repo-scale work: LLM-council planning, Ralph-loop recovery, isolated OpenCode worktrees, and human-gated PR delivery.",
  "type": "module",
  "keywords": [
    "ai-orchestration",
    "llm-orchestration",
    "agent-orchestration",
    "multi-agent-orchestration",
    "multi-agent-systems",
    "ai-agents",
    "agentic-ai",
    "agentic-coding",
    "agentic-workflow",
    "coding-agent",
    "ai-coding",
    "ai-code-generation",
    "llm-council",
    "ralph-loop",
    "opencode",
    "git-worktree",
    "human-in-the-loop",
    "developer-tools",
    "typescript",
    "sqlite"
  ],
  "author": "LoopTroop AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/looptroop-ai/LoopTroop.git"
  },
  "bugs": {
    "url": "https://github.com/looptroop-ai/LoopTroop/issues"
  },
  "homepage": "https://www.looptroop.ovh/",
  "scripts": {
    "predev": "node scripts/dev-preflight.mjs",
    "dev": "tsx scripts/dev.ts",
    "dev:app": "concurrently -n fe,be -c blue,green \"npm:dev:frontend\" \"npm:dev:backend\"",
    "deps:sync": "tsx scripts/dev-deps.ts",
    "audit:remediate": "tsx scripts/dev-audit.ts",
    "opencode:upgrade": "tsx scripts/dev-opencode-upgrade.ts",
    "dev:opencode": "tsx scripts/dev-opencode.ts",
    "dev:frontend": "vite",
    "dev:backend": "tsx scripts/dev-backend.ts",
    "docs:dev": "tsx scripts/dev-docs.ts",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "site:build": "npm run docs:build && node scripts/build-site.mjs",
    "diagnose:stall": "tsx scripts/diagnose-runtime-stall.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:client": "vitest run --project client-dom --project client-node",
    "test:server": "vitest run --project server-pure --project server-integration",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate --config=drizzle.app.config.ts",
    "db:generate:app": "drizzle-kit generate --config=drizzle.app.config.ts",
    "db:generate:project": "drizzle-kit generate --config=drizzle.project.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.app.config.ts",
    "db:push:app": "drizzle-kit push --config=drizzle.app.config.ts",
    "db:push:project": "drizzle-kit push --config=drizzle.project.config.ts"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.2",
    "@hono/node-server": "^2.0.6",
    "@opencode-ai/sdk": "^1.17.12",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-hover-card": "^1.1.17",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-query": "^5.101.1",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "gpt-tokenizer": "^3.4.0",
    "hono": "^4.12.27",
    "js-yaml": "^5.1.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "xstate": "^5.32.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "mermaid": "^11.15.0",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.3.1",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9"
  }
}
