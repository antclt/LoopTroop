# Runtime mode used by the backend and shared config helpers.
NODE_ENV=development

# Optional override for the LoopTroop config directory.
LOOPTROOP_CONFIG_DIR=.looptroop

# Optional override for the main app SQLite database path.
LOOPTROOP_APP_DB_PATH=.looptroop/app.sqlite

# Frontend dev server port. When LOOPTROOP_FRONTEND_ORIGIN is unset, the
# default frontend origin is derived as http://localhost:<this port>.
LOOPTROOP_FRONTEND_PORT=5173

# Optional explicit frontend origin exposed to the backend and app links.
# Invalid values fall back to the default derived from LOOPTROOP_FRONTEND_PORT.
# LOOPTROOP_FRONTEND_ORIGIN=http://localhost:5173

# Docs dev server port.
LOOPTROOP_DOCS_PORT=5174

# Docs origin exposed to the frontend.
LOOPTROOP_DOCS_ORIGIN=http://localhost:5174

# Backend API port.
LOOPTROOP_BACKEND_PORT=3000

# Base URL for the OpenCode server or compatible endpoint.
LOOPTROOP_OPENCODE_BASE_URL=http://127.0.0.1:4096

# Set to mock to use the in-process OpenCode mock adapter.
LOOPTROOP_OPENCODE_MODE=

# Optional basic-auth username for the OpenCode dev server.
OPENCODE_SERVER_USERNAME=opencode

# Optional basic-auth password for the OpenCode dev server.
OPENCODE_SERVER_PASSWORD=change-me

# Set to 1 for verbose dev maintenance and startup logging.
LOOPTROOP_DEV_VERBOSE=0

# Set to 1 to skip dependency sync and npm audit remediation.
LOOPTROOP_DEV_SKIP_DEPS=0

# Set to 1 to skip automatic OpenCode CLI upgrades.
LOOPTROOP_DEV_SKIP_OPENCODE_UPGRADE=0

# Set to 1 to force daily-gated maintenance to run now.
LOOPTROOP_DEV_FORCE_MAINTENANCE=0

# Set to 1 to silence test-only console output.
LOOPTROOP_TEST_SILENT=0

# Optional file-watching override for mounted or network filesystems.
CHOKIDAR_USEPOLLING=0

# Vitest sets this automatically during tests.
# VITEST=1

# Optional XDG config base directory used when LOOPTROOP_CONFIG_DIR is unset.
# XDG_CONFIG_HOME=/home/you/.config

# WSL detection hint that is usually provided by the shell.
# WSL_DISTRO_NAME=Ubuntu

# Additional WSL detection hint that is usually provided by the shell.
# WSL_INTEROP=/run/WSL/123_interop

# Standard shell home directory used by diagnostics and default config resolution.
# HOME=/home/you

# Disable ANSI colors in diagnostic script output.
# NO_COLOR=1

# Force ANSI colors in diagnostic script output.
# FORCE_COLOR=1
